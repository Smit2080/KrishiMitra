# ============================================================================
# KrishiMitra Environment Variables
# Copy this file to .env and fill in your values
# ============================================================================

# ─── SUPABASE (Required) ─────────────────────────────────────────────────────
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
# Server-side only (for payment writes via service role)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─── RAZORPAY (Required for online payments) ─────────────────────────────────
# Get test keys from: https://dashboard.razorpay.com/app/keys
RAZORPAY_KEY_ID=rzp_test_XXXXXXXXXXXX
RAZORPAY_KEY_SECRET=your-razorpay-secret
# Optional: Webhook secret for payment event verification
RAZORPAY_WEBHOOK_SECRET=your-webhook-secret

# ─── AI / GROQ (Optional - for AI advisory & chat) ───────────────────────────
# Get free key from: https://console.groq.com
GROQ_API_KEY=gsk_XXXXXXXXXXXX

# ─── WEATHER (Optional - for weather advisory) ───────────────────────────────
# Get free key from: https://openweathermap.org/api
OPENWEATHER_API_KEY=your-openweather-key

# ─── ADMIN ───────────────────────────────────────────────────────────────────
# Comma-separated emails that get admin panel access
VITE_ADMIN_EMAILS=admin@example.com

# ─── API URL (Optional - auto-detected in dev) ──────────────────────────────
# Set this in production to your Render backend URL
# VITE_API_URL=https://your-backend.onrender.com
